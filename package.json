{
  "name": "wallet-system",
  "version": "2.0.0",
  "main": "dist/server.js",
  "description": "Hierarchical wallet system with multi-level commission distribution",
  "scripts": {
    "lint": "eslint '**/*.ts'",
    "lint:fix": "eslint '**/*.ts' --fix",
    "format": "prettier --write '**/*.ts'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "code": "nodemon --watch 'src/**/*' -e ts,tsx --exec 'ts-node' ./src/server.ts",
    "build": "tsc -b tsconfig.json",
    "prod": "node dist/server.js",
    "start": "node .",
    "dev": "nodemon ./src/server.ts",
    "knex": "./node_modules/.bin/knex --knexfile src/database/database.connection.ts",
    "knex:wallet": "./node_modules/.bin/knex --knexfile src/database/wallet-connection.ts",
    "migrate:wallet": "npm run knex:wallet migrate:latest",
    "migrate:wallet:rollback": "npm run knex:wallet migrate:rollback",
    "seed:wallet": "npm run knex:wallet seed:run",
    "watch-server": "nodemon --watch 'src/**/*' -e ts,tsx --exec 'ts-node' ./src/server.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/storage": "^7.12.1",
    "@koa/cors": "^3.3.0",
    "@koa/multer": "^3.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.1",
    "@opentelemetry/sdk-metrics": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/sdk-trace-node": "^1.25.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "koa-logger": "^3.2.1",
    "koa-router": "^12.0.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^3.3.0",
    "@types/koa__multer": "^2.0.7",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-logger": "^3.1.5",
    "@types/koa-router": "^7.4.8",
    "@types/nodemailer": "^6.4.23",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
