              "raw": "{\n  \"token\": \"{{inviteToken}}\",\n  \"password\": \"SecurePass@123\",\n  \"mpin\": \"654321\"\n}"
            }
          }
        },
        {
          "name": "4. Get My Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "users", "me"]
            }
          }
        },
        {
