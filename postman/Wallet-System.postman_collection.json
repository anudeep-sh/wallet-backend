{
  "info": {
    "name": "Wallet System API",
    "description": "Full API collection for the hierarchical wallet system.\n\nSwitch between LOCAL and HOSTED environments — all requests use {{baseUrl}}.\n\nLogin flow auto-saves accessToken and refreshToken to environment variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [],
  "item": [
    {
      "name": "Auth",
      "description": "OTP-based login, MPIN verification, token refresh, logout",
      "item": [
        {
          "name": "1. Request OTP (email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/auth/request-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "auth", "request-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{adminEmail}}\",\n  \"channel\": \"email\"\n}"
            }
          }
        },
        {
          "name": "2. Request OTP (phone)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/auth/request-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "auth", "request-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"+919999999999\",\n  \"channel\": \"sms\"\n}"
            }
          }
        },
        {
          "name": "3. Verify OTP ✅ (saves tokens)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.environment.set('accessToken', json.accessToken);",
                  "  pm.environment.set('refreshToken', json.refreshToken);",
                  "  pm.environment.set('userId', json.user.id);",
                  "  pm.test('Tokens saved to env', function() {",
                  "    pm.expect(json.accessToken).to.be.a('string');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "auth", "verify-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{adminEmail}}\",\n  \"otp\": \"PASTE_OTP_HERE\"\n}"
            }
          }
        },
        {
          "name": "4. Verify MPIN",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/auth/verify-mpin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "auth", "verify-mpin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mpin\": \"{{adminMpin}}\"\n}"
            }
          }
        },
        {
          "name": "5. Refresh Token ✅ (saves new tokens)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.environment.set('accessToken', json.accessToken);",
                  "  pm.environment.set('refreshToken', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "auth", "refresh-token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "6. Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "Invite, register, profile, downline management",
      "item": [
        {
          "name": "1. Invite User ✅ (saves inviteToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.environment.set('invitationId', json.invitationId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/users/invite",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "users", "invite"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleId\": 2,\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"mobileNumber\": \"+919876543210\",\n  \"gender\": \"male\",\n  \"dateOfBirth\": \"1990-05-15\",\n  \"address1\": \"123 Main Street\",\n  \"address2\": \"Apt 4B\",\n  \"city\": \"Hyderabad\",\n  \"state\": \"Telangana\",\n  \"pincode\": \"500001\",\n  \"panCardNumber\": \"ABCDE1234F\",\n  \"aadharCardNumber\": \"123456789012\",\n  \"nameOnAadhar\": \"John Doe\",\n  \"bankAccountNumber\": \"1234567890123456\",\n  \"ifscCode\": \"SBIN0001234\",\n  \"depositLimit\": 500000,\n  \"withdrawDailyLimit\": 100000,\n  \"fileUrls\": []\n}"
            }
          }
