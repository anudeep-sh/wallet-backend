    {
      "name": "Payins (Credit Card Swipe)",
      "description": "Initiate Razorpay payment, verify, webhook",
      "item": [
        {
          "name": "1. Initiate Payin ✅ (saves payinId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.environment.set('payinId', json.payinId);",
                  "  pm.environment.set('razorpayOrderId', json.orderId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/payins/initiate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "payins", "initiate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 10000\n}"
            }
          }
        },
        {
          "name": "2. Verify Payin (after Razorpay checkout)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/payins/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "payins", "verify"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpayOrderId\": \"{{razorpayOrderId}}\",\n  \"razorpayPaymentId\": \"pay_XXXXXXXXXXXX\",\n  \"razorpaySignature\": \"PASTE_SIGNATURE_HERE\"\n}"
            }
          }
        },
        {
          "name": "3. Razorpay Webhook (no auth)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "x-razorpay-signature",
                "value": "PASTE_WEBHOOK_SIGNATURE"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/payins/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "payins", "webhook"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"pay_XXXXXXXXXXXX\",\n        \"order_id\": \"{{razorpayOrderId}}\",\n        \"amount\": 1000000,\n        \"status\": \"captured\"\n      }\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "4. List My Payins",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/payins?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "payins"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "5. Get Payin Details (with commission breakdown)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/payins/{{payinId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "payins", "{{payinId}}"]
            }
          }
        }
      ]
    },
