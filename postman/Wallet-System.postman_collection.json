          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "users", "me"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\"\n}"
            }
          }
        },
        {
          "name": "6. Set / Change MPIN",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
